rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isHouseholdMember(householdId) {
      let hh = get(/databases/$(database)/documents/households/$(householdId));
      return hh != null && request.auth.uid in hh.data.members.map(m, m.userId);
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Transactions ──────────────────────────────────────────
    match /transactions/{txId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Categories ────────────────────────────────────────────
    match /categories/{catId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Budgets ───────────────────────────────────────────────
    match /budgets/{budgetId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Households ────────────────────────────────────────────
    match /households/{householdId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.members.map(m, m.userId)
      );
    }

    // ── Email Import Config ───────────────────────────────────
    match /emailImportConfig/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Pending Imports (written by Cloud Function via admin SDK) ──
    match /pendingImports/{importId} {
      allow read, update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.householdId != null && isHouseholdMember(resource.data.householdId))
      );
      // Cloud Function writes with admin SDK (bypasses rules) — no client create needed
    }

    // ── Invites ───────────────────────────────────────────────
    match /invites/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.inviteeEmail == request.auth.token.email
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.inviteeEmail == request.auth.token.email ||
        get(/databases/$(database)/documents/households/$(resource.data.householdId)).data.ownerId == request.auth.uid
      );
    }

  }
}
