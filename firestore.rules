rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isHouseholdMember(householdId) {
      let hh = get(/databases/$(database)/documents/households/$(householdId));
      return hh != null && (
        hh.data.ownerId == request.auth.uid ||
        hh.data.members.filter(m, m.userId == request.auth.uid).size() > 0
      );
    }
    function isSavingsAccountOwner(accountId) {
      let acc = get(/databases/$(database)/documents/savingsAccounts/$(accountId));
      return acc != null && (
        acc.data.ownerId == request.auth.uid ||
        isHouseholdMember(acc.data.ownerId)
      );
    }
    function isLoanAccountOwner(accountId) {
      let acc = get(/databases/$(database)/documents/loanAccounts/$(accountId));
      return acc != null && (
        acc.data.ownerId == request.auth.uid ||
        isHouseholdMember(acc.data.ownerId)
      );
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Transactions ──────────────────────────────────────────
    match /transactions/{txId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Categories ────────────────────────────────────────────
    match /categories/{catId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Budgets ───────────────────────────────────────────────
    match /budgets/{budgetId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Budget Overrides (per-month adjustments) ──────────────
    match /budgetOverrides/{ovId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Savings Accounts ──────────────────────────────────────
    match /savingsAccounts/{accId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Savings Transactions ──────────────────────────────────
    match /savingsTxs/{txId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.createdBy == request.auth.uid)
          : (resource.data.createdBy == request.auth.uid ||
             isSavingsAccountOwner(resource.data.accountId))
      );
    }

    // ── Loan Accounts ─────────────────────────────────────────
    match /loanAccounts/{accId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Loan Transactions ─────────────────────────────────────
    match /loanTxs/{txId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.createdBy == request.auth.uid)
          : (resource.data.createdBy == request.auth.uid ||
             isLoanAccountOwner(resource.data.accountId))
      );
    }

    // ── Households ────────────────────────────────────────────
    match /households/{householdId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.members.filter(m, m.userId == request.auth.uid).size() > 0
      );
    }

    // ── Email Import Config ───────────────────────────────────
    match /emailImportConfig/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Trash (soft-deleted transactions, auto-purge after 30 days) ──
    match /trash/{docId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Category Mappings (smart auto-categorization) ─────────
    match /categoryMappings/{mappingId} {
      allow read, write: if isSignedIn() && (
        resource == null
          ? (request.resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(request.resource.data.ownerId))
          : (resource.data.ownerId == request.auth.uid ||
             isHouseholdMember(resource.data.ownerId))
      );
    }

    // ── Pending Imports (written by Cloud Function via admin SDK) ──
    match /pendingImports/{importId} {
      allow read, update, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        (resource.data.householdId != null && isHouseholdMember(resource.data.householdId))
      );
      // Cloud Function writes with admin SDK (bypasses rules) — no client create needed
    }

    // ── Invites ───────────────────────────────────────────────
    match /invites/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.inviteeEmail == request.auth.token.email
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.inviteeEmail == request.auth.token.email ||
        get(/databases/$(database)/documents/households/$(resource.data.householdId)).data.ownerId == request.auth.uid
      );
    }

  }
}
